# =============================================================================
# PARKFLOW PORTS CONFIGURATION
# =============================================================================
# Este archivo define todos los puertos usados por los servicios de Parkflow.
# Copia este archivo a `.env` y ajusta según tus necesidades.
#
# Para aplicar cambios: reiniciar todos los servicios.
# =============================================================================

# -----------------------------------------------------------------------------
# WEB / Next.js
# -----------------------------------------------------------------------------
PARKFLOW_WEB_PORT=6001
PARKFLOW_WEB_FALLBACK_PORT=6002

# -----------------------------------------------------------------------------
# API / Spring Boot
# -----------------------------------------------------------------------------
PARKFLOW_API_PORT=6011
PARKFLOW_API_FALLBACK_PORT=6012

# -----------------------------------------------------------------------------
# Database / PostgreSQL
# -----------------------------------------------------------------------------
PARKFLOW_DB_PORT=6021
POSTGRES_USER=parkflow
POSTGRES_PASSWORD=parkflow
POSTGRES_DB=parkflow_dev

# -----------------------------------------------------------------------------
# Cache / Redis
# -----------------------------------------------------------------------------
PARKFLOW_REDIS_PORT=6031

# -----------------------------------------------------------------------------
# Desktop Bridge / Tauri Local Agent
# -----------------------------------------------------------------------------
PARKFLOW_DESKTOP_BRIDGE_PORT=6041
PARKFLOW_DESKTOP_BRIDGE_FALLBACK_PORT=6042

# -----------------------------------------------------------------------------
# Printer Service
# -----------------------------------------------------------------------------
PARKFLOW_PRINTER_PORT=6051
PARKFLOW_PRINTER_FALLBACK_PORT=6052

# -----------------------------------------------------------------------------
# WebSocket / Realtime
# -----------------------------------------------------------------------------
PARKFLOW_WS_PORT=6061
PARKFLOW_WS_FALLBACK_PORT=6062

# =============================================================================
# DERIVED URLs (calculados automáticamente, no modificar manualmente)
# =============================================================================
# Estas variables se construyen a partir de los puertos definidos arriba.
# Los scripts de desarrollo las actualizan automáticamente.

NEXT_PUBLIC_API_BASE_URL=http://localhost:${PARKFLOW_API_PORT}/api/v1/operations
NEXT_PUBLIC_AUTH_BASE_URL=http://localhost:${PARKFLOW_API_PORT}/api/v1/auth
NEXT_PUBLIC_WS_URL=ws://localhost:${PARKFLOW_WS_PORT}
API_BASE_URL=http://localhost:${PARKFLOW_API_PORT}

# =============================================================================
# SECURITY VARIABLES (REQUIRED)
# =============================================================================
# Estas variables SON OBLIGATORIAS para el funcionamiento de la API.
# Deben configurarse antes de iniciar los servicios.

# JWT Secret en Base64 (generar con: openssl rand -base64 32)
PARKFLOW_JWT_SECRET_BASE64=VKShGl6Hkv2V4dxJ2R6OOSSQqBGP4CILhK5neP5B6zA=

# API Key para validación interna
PARKFLOW_API_KEY=dev-api-key-123

# =============================================================================
# OPTIONAL SECURITY SETTINGS
# =============================================================================
PARKFLOW_ACCESS_TOKEN_TTL_MINUTES=15
PARKFLOW_REFRESH_TOKEN_TTL_DAYS=7
PARKFLOW_OFFLINE_LEASE_HOURS=48

# =============================================================================
# CASH MODULE SETTINGS
# =============================================================================
PARKFLOW_CASH_REQUIRE_OPEN=true
PARKFLOW_CASH_OFFLINE_CLOSE=false
PARKFLOW_CASH_OFFLINE_MAX_MANUAL=500000
PARKFLOW_CASH_OPS_HINT="Abra caja en el mismo terminal que el cobro"

# =============================================================================
# DESKTOP/DEVICE SETTINGS
# =============================================================================
NEXT_PUBLIC_TERMINAL_ID=DEV-001
NEXT_PUBLIC_DEVICE_ID=dev-device-001
NEXT_PUBLIC_DEVICE_NAME="Development Workstation"
NEXT_PUBLIC_DEVICE_PLATFORM=desktop
NEXT_PUBLIC_DEVICE_FINGERPRINT=dev-fingerprint-001

# =============================================================================
# PRINTER SETTINGS
# =============================================================================
NEXT_PUBLIC_PRINTER_PROFILE=generic_58mm_esc_pos
NEXT_PUBLIC_PRINTER_STRICT_MODE=false
