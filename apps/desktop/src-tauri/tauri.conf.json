{
  "productName": "Parkflow Desktop",
  "identifier": "com.parkflow.desktop",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "pnpm -C ../.. dev:web",
    "beforeBuildCommand": "pnpm -C ../.. build:web",
    "devUrl": "http://localhost:6001",
    "frontendDist": "../../web/.next"
  },
  "app": {
    "windows": [
      {
        "title": "Parkflow Desktop",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default", "licensing"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
