generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VehicleType {
  CAR
  MOTORCYCLE
  TRUCK
  VAN
  OTHER
}

enum SessionStatus {
  ACTIVE
  CLOSED
  CANCELED
}

enum RateType {
  HOURLY
  DAILY
  FLAT
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum CashClosureStatus {
  OPEN
  CLOSED
}

enum SettingValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
}

model User {
  id          String           @id @default(cuid())
  name        String
  email       String           @unique
  role        UserRole         @default(CASHIER)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  opened      CashClosure[]    @relation("CashClosureOpenedBy")
  closed      CashClosure[]    @relation("CashClosureClosedBy")
}

model Vehicle {
  id        String           @id @default(cuid())
  plate     String           @unique
  type      VehicleType
  color     String?
  brand     String?
  model     String?
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  sessions  ParkingSession[]

  @@index([type])
  @@index([createdAt])
}

model Rate {
  id          String           @id @default(cuid())
  name        String
  vehicleType VehicleType?
  rateType    RateType
  amount      Decimal          @db.Decimal(10, 2)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  sessions    ParkingSession[]

  @@index([isActive])
  @@index([rateType])
}

model ParkingSession {
  id          String         @id @default(cuid())
  vehicleId   String
  rateId      String?
  entryAt     DateTime       @default(now())
  exitAt      DateTime?
  status      SessionStatus  @default(ACTIVE)
  totalAmount Decimal?       @db.Decimal(10, 2)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  vehicle     Vehicle        @relation(fields: [vehicleId], references: [id])
  rate        Rate?          @relation(fields: [rateId], references: [id])
  payment     Payment?

  @@index([status, entryAt])
  @@index([vehicleId])
  @@index([rateId])
}

model Payment {
  id        String         @id @default(cuid())
  sessionId String         @unique
  method    PaymentMethod
  amount    Decimal        @db.Decimal(10, 2)
  paidAt    DateTime       @default(now())
  reference String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  session   ParkingSession @relation(fields: [sessionId], references: [id])

  @@index([paidAt])
}

model CashClosure {
  id             String            @id @default(cuid())
  openedById     String
  closedById     String?
  openedAt       DateTime          @default(now())
  closedAt       DateTime?
  openingAmount  Decimal           @db.Decimal(10, 2)
  closingAmount  Decimal?          @db.Decimal(10, 2)
  expectedAmount Decimal?          @db.Decimal(10, 2)
  variance       Decimal?          @db.Decimal(10, 2)
  status         CashClosureStatus @default(OPEN)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  openedBy       User              @relation("CashClosureOpenedBy", fields: [openedById], references: [id])
  closedBy       User?             @relation("CashClosureClosedBy", fields: [closedById], references: [id])

  @@index([status, openedAt])
}

model AppSetting {
  id          String           @id @default(cuid())
  key         String           @unique
  value       String
  valueType   SettingValueType @default(STRING)
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}
