# =============================================================================
# WEB APP ENVIRONMENT VARIABLES
# =============================================================================
# Este archivo define las variables específicas para la aplicación web.
# Los valores de puertos se heredan o definen en el .env del root del monorepo.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (para Prisma en desarrollo local)
# -----------------------------------------------------------------------------
POSTGRES_USER=parkflow
POSTGRES_PASSWORD=parkflow
POSTGRES_DB=parkflow_dev
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:6021/${POSTGRES_DB}?schema=public

# -----------------------------------------------------------------------------
# NEXT.JS SERVER PORT
# -----------------------------------------------------------------------------
# Este puerto es determinado por el script dev-web.mjs
# No establecer manualmente - usar PARKFLOW_WEB_PORT en el root .env
PORT=6001

# -----------------------------------------------------------------------------
# API ENDPOINTS
# -----------------------------------------------------------------------------
# NOTA: Estas URLs se actualizan automáticamente por el script de desarrollo
# Basado en PARKFLOW_API_PORT y PARKFLOW_WS_PORT del root .env
NEXT_PUBLIC_API_BASE_URL=http://localhost:6011/api/v1/operations
NEXT_PUBLIC_AUTH_BASE_URL=http://localhost:6011/api/v1/auth
NEXT_PUBLIC_WS_URL=ws://localhost:6061

# -----------------------------------------------------------------------------
# API SECURITY
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_KEY=parkflow-dev-key

# -----------------------------------------------------------------------------
# TERMINAL / DEVICE CONFIGURATION
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TERMINAL_ID=WEB-001
NEXT_PUBLIC_DEVICE_ID=web-dev-001
NEXT_PUBLIC_DEVICE_NAME="Web Development"
NEXT_PUBLIC_DEVICE_PLATFORM=web
NEXT_PUBLIC_DEVICE_FINGERPRINT=web-fingerprint-001

# -----------------------------------------------------------------------------
# PRINTER CONFIGURATION
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PRINTER_PROFILE=generic_58mm_esc_pos
# Set to true in QA/certification to fail fast on unknown profiles
NEXT_PUBLIC_PRINTER_STRICT_MODE=false
